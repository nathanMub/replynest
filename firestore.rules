rules_version = '2';
service cloudfirestore {
  match /databases/{database}/documents {

    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // STANDALONE HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation Helpers
    function isValidBusinessProfile(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'email', 'businessName', 'industry', 'businessDescription'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.businessName is string && data.businessName.size() <= 200
        && data.industry is string && data.industry.size() <= 200
        && data.businessDescription is string && data.businessDescription.size() <= 2000;
    }

    function isValidUserPlan(data) {
      return data.keys().hasAll(['id', 'userId', 'plan', 'repliesRemaining', 'totalRepliesGenerated', 'subscriptionStatus'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.plan is string && data.plan.size() <= 50
        && data.repliesRemaining is int
        && data.totalRepliesGenerated is int
        && data.subscriptionStatus is string && data.subscriptionStatus.size() <= 50;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'photoURL', 'createdAt', 'lastLogin', 'plan', 'freeRepliesRemaining', 'totalRepliesGenerated', 'subscriptionStatus'])
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.photoURL is string && data.photoURL.size() <= 2000
        && data.plan is string && data.plan.size() <= 50
        && data.freeRepliesRemaining is int
        && data.totalRepliesGenerated is int
        && data.subscriptionStatus is string && data.subscriptionStatus.size() <= 50;
    }

    // COLLECTION MATCH RULES

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    // 2. UserPlans Collection
    match /userPlans/{planId} {
      // Guests can read/write their guest plan tracking documents (prefixed with 'guest_')
      // Authenticated users can read/write only their own user plan document
      allow read: if planId.startsWith('guest_') || isOwner(planId);
      allow create, update: if planId.startsWith('guest_') || (isOwner(planId) && isValidUserPlan(request.resource.data));
      allow delete: if false;
    }

    // 3. Business Profiles Collection
    match /businessProfiles/{profileId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && isValidBusinessProfile(request.resource.data);
    }

    // 4. Saved Products Collection
    match /savedProducts/{productId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 5. Saved FAQs Collection
    match /savedFaqs/{faqId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 6. User Settings Collection
    match /userSettings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
  }
}
